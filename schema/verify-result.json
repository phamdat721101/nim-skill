{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/phamdat721101/nim-skill/schema/verify-result.json",
  "title": "VerifyResult",
  "type": "object",
  "required": ["verified", "heals", "checks", "output"],
  "properties": {
    "verified": { "type": "boolean" },
    "heals": { "type": "integer", "minimum": 0 },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["strategy", "pass"],
        "properties": {
          "strategy": { "type": "string" },
          "pass": { "type": "boolean" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "output": {}
  },
  "additionalProperties": false
}
