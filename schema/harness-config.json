{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/phamdat721101/nim-skill/schema/harness-config.json",
  "title": "nim.json harness config",
  "type": "object",
  "properties": {
    "harness": {
      "type": "object",
      "properties": {
        "guard": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "maxCostUsd": { "type": "number", "minimum": 0 },
                "ratePerMin": { "type": "integer", "minimum": 1 },
                "allowTools": { "type": "array", "items": { "type": "string" } },
                "injection": { "enum": ["off", "strict"] }
              },
              "additionalProperties": false
            }
          ]
        },
        "errorHandler": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "retries": { "type": "integer", "minimum": 0 },
                "backoff": { "enum": ["exp-jitter", "fixed", "none"] },
                "baseDelayMs": { "type": "integer", "minimum": 0 },
                "circuitBreaker": {
                  "oneOf": [
                    { "const": false },
                    {
                      "type": "object",
                      "properties": {
                        "failN": { "type": "integer", "minimum": 1 },
                        "cooldownMs": { "type": "integer", "minimum": 0 },
                        "windowSize": { "type": "integer", "minimum": 1 }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              },
              "additionalProperties": false
            }
          ]
        },
        "enforcer": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "strategies": { "type": "array" },
                "maxHeals": { "type": "integer" },
                "mode": { "enum": ["strict", "warn", "off"] },
                "strict": { "type": "boolean" },
                "healFeedback": { "enum": ["minimal", "full"] }
              },
              "additionalProperties": false
            }
          ]
        },
        "monitor": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "exporters": {
                  "type": "array",
                  "items": { "enum": ["console", "file", "sentry"] }
                },
                "traceFile": { "type": "string" },
                "tokenAccounting": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          ]
        },
        "context": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "progressive": { "type": "boolean" },
                "maxInputTokens": { "type": "integer", "minimum": 1 },
                "onExceed": { "enum": ["compact", "warn", "block"] },
                "lean": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          ]
        },
        "memory": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "verifyCache": { "type": "boolean" },
                "priors": { "type": "boolean" },
                "ttlMs": { "type": "integer", "minimum": 0 },
                "store": { "type": "string" }
              },
              "additionalProperties": false
            }
          ]
        },
        "execution": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "isolate": { "type": "boolean" },
                "isolateOnRetry": { "type": "boolean" }
              },
              "additionalProperties": false
            }
          ]
        },
        "cache": {
          "oneOf": [
            { "const": false },
            {
              "type": "object",
              "properties": {
                "provider": {
                  "enum": ["auto", "anthropic", "minimax", "qwen", "openai", "glm", "gemini", "deepseek"]
                },
                "strategy": { "enum": ["prefix", "explicit"] },
                "ttl": { "enum": ["5m", "1h"] },
                "minTokens": { "type": "integer", "minimum": 1 },
                "roi": { "type": "boolean" },
                "breakEvenReads": { "type": "number", "minimum": 0 },
                "prices": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "base": { "type": "number", "minimum": 0 },
                      "cachedRead": { "type": "number", "minimum": 0 }
                    }
                  }
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
